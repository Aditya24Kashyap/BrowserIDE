{
  "functions": {
    "app/api/template/[id]/route.ts": {
      "includeFiles": "vibecode-starters/**"
    }
  },
  "headers": [
    {
      "source": "/playground/:path*",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}